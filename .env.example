# Model Configuration
MODEL_NAME=all-MiniLM-L6-v2
# Alternatives: all-mpnet-base-v2 (higher accuracy, 2x memory), all-distilroberta-v1 (balanced)

# Directory Paths
RESUME_DIR=data/resumes
JD_DIR=data/job_descriptions
OUTPUT_DIR=data/outputs
CACHE_DIR=data/cache
LOG_DIR=data/logs

# Ranking Configuration
THRESHOLD=60.0
BIAS_DELTA_THRESHOLD=10.0
INFERRED_SIMILARITY_THRESHOLD=0.75

# Application
LOG_LEVEL=INFO
